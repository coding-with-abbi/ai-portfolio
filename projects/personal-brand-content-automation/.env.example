# =============================================================================
#  Personal Brand Content Automation -- Environment Variables
# =============================================================================
# Copy this file to .env and fill in your credentials.

# --- Azure OpenAI (REQUIRED) ------------------------------------------------
# Portal: https://portal.azure.com -> Azure OpenAI -> Keys and Endpoint
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# --- ElevenLabs (voice-over generation) -------------------------------------
# Dashboard: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# Voice ID -- default is "Adam"; find others at https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_ID=Adam

# --- Notion (content calendar & idea database) ------------------------------
# Create an integration at https://www.notion.so/my-integrations
NOTION_API_KEY=
# Database IDs from the URL of each Notion database page
NOTION_CALENDAR_DB_ID=
NOTION_IDEAS_DB_ID=

# --- SocialBlade (analytics / competitor tracking) --------------------------
# Register at https://socialblade.com/p/api
SOCIALBLADE_CLIENT_ID=
SOCIALBLADE_TOKEN=

# --- Canva (design generation) ----------------------------------------------
# Developer portal: https://www.canva.com/developers/
CANVA_API_KEY=

# --- OpusClip (AI video clipping) -------------------------------------------
# Dashboard: https://www.opus.pro/settings
OPUSCLIP_API_KEY=

# --- OpenAI / Sora (video generation) ---------------------------------------
# Platform: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- General ----------------------------------------------------------------
# Language code for generated content (default: de)
CONTENT_LANGUAGE=de
# Directory where all generated assets are saved
OUTPUT_DIR=output
# Comma-separated list of target platforms
DEFAULT_PLATFORMS=instagram,tiktok,linkedin,youtube,x
